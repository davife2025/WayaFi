# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# API
API_PORT=3001
JWT_SECRET=your_jwt_secret_here
DATABASE_URL=postgresql://user:password@localhost:5432/stablehacks

# Compliance
ELLIPTIC_API_KEY=your_elliptic_api_key
CHAINALYSIS_API_KEY=your_chainalysis_api_key
SMILE_ID_API_KEY=your_smile_id_api_key

# SIX Data Partner
SIX_API_KEY=your_six_api_key
SIX_FX_ENDPOINT=https://api.six-group.com/api/findata/v1

# Travel Rule
TRISA_ENDPOINT=your_trisa_endpoint
TRISA_CERT_PATH=./certs/trisa.pem

# On/Off Ramp
YELLOW_CARD_API_KEY=your_yellow_card_api_key
BITNOB_API_KEY=your_bitnob_api_key
